<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tailor.model-advisor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jarvis/tailor/.venv/bin/python3</string>
        <string>/Users/jarvis/tailor/scripts/services/model_advisor.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/jarvis/tailor</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>TAILOR_HOME</key>
        <string>/Users/jarvis/tailor</string>
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/jarvis/tailor/logs/model_advisor_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/jarvis/tailor/logs/model_advisor_stderr.log</string>
</dict>
</plist>
