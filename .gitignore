# ═══════════════════════════════════════════════════════════════
# TAILOR .gitignore
# ═══════════════════════════════════════════════════════════════

# ── User data (NEVER commit) ─────────────────────────────────
# Use db/* (not db/) so specific subpaths can be re-included below
db/*
data/
credentials/
backups/
.backups/
logs/

# ── Exceptions: SQL schema migrations SHOULD be tracked ──────
!db/migrations/
!db/migrations/*.sql

# ── Config with secrets ──────────────────────────────────────
config/tailor.yaml
config/.backups/
.env
.env.local
.env.*.local

# ── Internal operational runbooks (NEVER commit) ─────────────
SECRETS.md

# ── Archive (old scripts, backups, dated READMEs) ────────────
archive/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# ── OS junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo

# ── Models (downloaded at setup, too large for git) ──────────
models/
*.bak*

# Chrome Web Store assets
docs/store/

# Local scratch prompts (not for repo)
prompts/
